{
  "crons": [
    {
      "path": "/api/reports/send",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/usage-reset",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/inbox-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/repurpose-sources",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "src/app/api/posts/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/upload/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/send/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/publish-scheduled/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/repurpose-sources/route.ts": {
      "maxDuration": 300
    }
  }
}
