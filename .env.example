# Database (Supabase PostgreSQL)
# App runtime: Transaction pooler (port 6543) — required for serverless/Render
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Migrations only: Session pooler (port 5432) — used by drizzle-kit push/generate
DIRECT_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Optional: Supabase project URL + anon key (for future client features; auth uses custom JWT)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth
AUTH_SECRET=generate-a-random-32-char-secret-here

# App URL (used for OAuth redirect URIs)
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare R2 (media storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Media processing (optional — defaults to bundled ffmpeg-static binary)
# FFMPEG_PATH=
# FFPROBE_PATH=

# TikTok OAuth + Content Posting API
# Register redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/tiktok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube OAuth (Google Cloud Console)
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/youtube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Instagram OAuth (Meta / Facebook App)
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/instagram
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Facebook OAuth (Meta / Facebook App)
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Google Drive backup
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/google-drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Create in Stripe Dashboard (Products) or use lookup keys: resocial_{plan}_{interval}
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_AGENCY_MONTHLY=price_xxx
STRIPE_PRICE_AGENCY_ANNUAL=price_xxx

# Scheduled email reports (Resend — https://resend.com/api-keys)
# Replace re_xxxxxxxxx with your real API key
RESEND_API_KEY=re_xxxxxxxxx
# Use onboarding@resend.dev for testing; use your verified domain in production
REPORT_FROM_EMAIL=ReSocial <onboarding@resend.dev>
# Optional: recipient for `node scripts/send-test-email.mjs`
# RESEND_TEST_TO=you@example.com
CRON_SECRET=generate-a-random-cron-secret
# Optional: Calendly or contact link for fair-use cap emails
# USAGE_CONTACT_URL=https://calendly.com/your-team/resocial

# Other platform OAuth (configure when ready)
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
