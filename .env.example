# Database (Neon PostgreSQL / Supabase)
DATABASE_URL=postgresql://user:password@host/resocial?sslmode=require

# Auth
AUTH_SECRET=generate-a-random-32-char-secret-here

# App URL (used for OAuth redirect URIs)
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare R2 (media storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Media processing (optional — defaults to bundled ffmpeg-static binary)
# FFMPEG_PATH=
# FFPROBE_PATH=

# TikTok OAuth + Content Posting API
# Register redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/tiktok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube OAuth (Google Cloud Console)
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/youtube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Instagram OAuth (Meta / Facebook App)
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/instagram
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Facebook OAuth (Meta / Facebook App)
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# LinkedIn OAuth
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google Drive backup
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/callback/google-drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly
STRIPE_PRICE_AGENCY_ANNUAL=price_agency_annual

# Other platform OAuth (configure when ready)
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
